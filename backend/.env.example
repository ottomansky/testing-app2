# Keboola Storage API credentials
# In production: auto-injected via dataApp.secrets
# For local dev: copy this file to .env and fill in your values
KBC_TOKEN=your-storage-api-token
KBC_URL=https://connection.europe-west3.gcp.keboola.com

# Optional: Keboola project ID (auto-derived from token if not set)
# KBC_PROJECTID=12345

# Local dev: simulate a logged-in user (Keboola OIDC header)
DEV_USER_EMAIL=dev@localhost
